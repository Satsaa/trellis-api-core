# Sentry (optional — skip to disable error reporting in edge functions)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Resend (email)
RESEND_API_KEY=re_xxx

# Unsubscribe link signing (required for suppressible emails)
UNSUBSCRIBE_SECRET=your-random-secret-here
UNSUBSCRIBE_BASE_URL=https://bxyhzvtycfdahafnmpjz.supabase.co/functions/v1/unsubscribe
